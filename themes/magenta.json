  "tokenColors": [

    // ── Base ─────────────────────────────────────────────────────────────────

    {
      "name": "Default text",
      "scope": ["source", "text"],
      "settings": { "foreground": "#e2cfe8" }
    },

    // ── Comments ─────────────────────────────────────────────────────────────

    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6a4a7a", "fontStyle": "italic" }
    },
    {
      "name": "Doc comments",
      "scope": ["comment.block.documentation", "comment.line.double-slash.documentation"],
      "settings": { "foreground": "#7a5888", "fontStyle": "italic" }
    },

    // ── Strings ──────────────────────────────────────────────────────────────

    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#c8d8a0" }
    },
    {
      "name": "String escape sequences",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#e0c878" }
    },
    {
      "name": "Template expression",
      "scope": ["punctuation.definition.template-expression"],
      "settings": { "foreground": "#e06bbd" }
    },

    // ── Numbers, booleans, constants ─────────────────────────────────────────

    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#e0c878" }
    },
    {
      "name": "Booleans and null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#c090e0" }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.language"],
      "settings": { "foreground": "#c090e0" }
    },
    {
      "name": "User-defined constants",
      "scope": ["constant.other", "variable.other.constant"],
      "settings": { "foreground": "#d090c8" }
    },

    // ── Keywords ─────────────────────────────────────────────────────────────

    {
      "name": "Keywords — control flow",
      "scope": [
        "keyword.control",
        "keyword.control.import", "keyword.control.export",
        "keyword.control.from",   "keyword.control.as",
        "keyword.control.return", "keyword.control.if",
        "keyword.control.else",   "keyword.control.for",
        "keyword.control.while",  "keyword.control.switch",
        "keyword.control.case",   "keyword.control.default",
        "keyword.control.break",  "keyword.control.continue",
        "keyword.control.try",    "keyword.control.catch",
        "keyword.control.finally","keyword.control.throw",
        "keyword.control.async",  "keyword.control.await",
        "keyword.control.yield"
      ],
      "settings": { "foreground": "#e06bbd", "fontStyle": "bold" }
    },
    {
      "name": "Keywords — other",
      "scope": ["keyword", "keyword.other"],
      "settings": { "foreground": "#c44fa0" }
    },
    {
      "name": "Keywords — operator word",
      "scope": ["keyword.operator.word", "keyword.operator.new", "keyword.operator.delete", "keyword.operator.typeof", "keyword.operator.instanceof", "keyword.operator.in", "keyword.operator.of"],
      "settings": { "foreground": "#d060b0" }
    },

    // ── Operators & punctuation ───────────────────────────────────────────────

    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#b07ac8" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#9060a8" }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.definition.block",
        "meta.brace.curly",
        "meta.brace.round",
        "meta.brace.square"
      ],
      "settings": { "foreground": "#c070b8" }
    },

    // ── Storage / types ───────────────────────────────────────────────────────

    {
      "name": "Storage — var, let, const, function, class",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#e06bbd", "fontStyle": "bold" }
    },

    // ── Types (TypeScript / Flow / Rust etc.) ────────────────────────────────

    {
      "name": "Type annotations",
      "scope": [
        "support.type",
        "entity.name.type",
        "entity.name.type.alias",
        "entity.name.type.interface",
        "entity.other.inherited-class",
        "meta.type.annotation",
        "meta.type.parameters"
      ],
      "settings": { "foreground": "#c9a8d4" }
    },
    {
      "name": "Type primitives",
      "scope": [
        "support.type.primitive",
        "keyword.type",
        "storage.type.boolean.go",
        "storage.type.string.go",
        "storage.type.numeric.go"
      ],
      "settings": { "foreground": "#b87fc8" }
    },

    // ── Functions ─────────────────────────────────────────────────────────────

    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#f090d0" }
    },
    {
      "name": "Function calls",
      "scope": ["meta.function-call.generic", "meta.method-call"],
      "settings": { "foreground": "#e880c8" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.parameters variable.other"],
      "settings": { "foreground": "#d8a8e0", "fontStyle": "italic" }
    },

    // ── Variables ─────────────────────────────────────────────────────────────

    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#e2cfe8" }
    },
    {
      "name": "this / self",
      "scope": ["variable.language.this", "variable.language.self", "variable.language.super"],
      "settings": { "foreground": "#e06bbd", "fontStyle": "italic" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "support.variable.property", "meta.property-name"],
      "settings": { "foreground": "#d8b0e0" }
    },

    // ── Classes ────────────────────────────────────────────────────────────────

    {
      "name": "Class names",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": { "foreground": "#c9a8d4", "fontStyle": "bold" }
    },
    {
      "name": "Constructors / new",
      "scope": ["meta.class entity.name.function"],
      "settings": { "foreground": "#c9a8d4" }
    },
    {
      "name": "Decorators / annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#a06bc8", "fontStyle": "italic" }
    },

    // ── Imports & namespaces ───────────────────────────────────────────────────

    {
      "name": "Module / namespace names",
      "scope": ["entity.name.namespace", "entity.name.module", "support.module"],
      "settings": { "foreground": "#b87fc8" }
    },
    {
      "name": "Import paths",
      "scope": ["string.quoted.double.import", "string.quoted.single.import"],
      "settings": { "foreground": "#c8d8a0" }
    },

    // ── Built-ins & support ────────────────────────────────────────────────────

    {
      "name": "Built-in functions and methods",
      "scope": ["support.function", "support.function.builtin"],
      "settings": { "foreground": "#e06bbd" }
    },
    {
      "name": "Built-in classes",
      "scope": ["support.class", "support.class.builtin"],
      "settings": { "foreground": "#c9a8d4" }
    },

    // ── HTML / JSX / TSX ──────────────────────────────────────────────────────

    {
      "name": "HTML tag names",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#e06bbd" }
    },
    {
      "name": "HTML attribute names",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#c9a8d4" }
    },
    {
      "name": "HTML attribute values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#c8d8a0" }
    },
    {
      "name": "JSX expression braces",
      "scope": ["punctuation.section.embedded"],
      "settings": { "foreground": "#e06bbd" }
    },
    {
      "name": "HTML entities",
      "scope": ["constant.character.entity.html", "punctuation.definition.entity.html"],
      "settings": { "foreground": "#e0c878" }
    },

    // ── CSS / SCSS ─────────────────────────────────────────────────────────────

    {
      "name": "CSS selectors",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#f090d0" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#c9a8d4" }
    },
    {
      "name": "CSS property values",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#c8d8a0" }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css", "constant.numeric.css"],
      "settings": { "foreground": "#e0c878" }
    },
    {
      "name": "CSS pseudo-selectors",
      "scope": ["entity.other.attribute-name.pseudo-class.css", "entity.other.attribute-name.pseudo-element.css"],
      "settings": { "foreground": "#a06bc8", "fontStyle": "italic" }
    },

    // ── Markdown ───────────────────────────────────────────────────────────────

    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#e06bbd", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#f090d0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#d8a8e0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#c8d8a0" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#e06bbd", "fontStyle": "underline" }
    },
    {
      "name": "Markdown list bullets",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#c44fa0" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#7a5888", "fontStyle": "italic" }
    },

    // ── JSON ───────────────────────────────────────────────────────────────────

    {
      "name": "JSON property keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#d8a8e0" }
    },

    // ── RegExp ─────────────────────────────────────────────────────────────────

    {
      "name": "Regex literals",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#e0c878" }
    },
    {
      "name": "Regex special chars",
      "scope": ["keyword.operator.quantifier.regexp", "keyword.operator.or.regexp", "keyword.control.anchor.regexp"],
      "settings": { "foreground": "#e06bbd" }
    },
    {
      "name": "Regex groups",
      "scope": ["punctuation.definition.group.regexp"],
      "settings": { "foreground": "#c44fa0" }
    },

    // ── Invalid / deprecated ───────────────────────────────────────────────────

    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#e05070", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#d0848a", "fontStyle": "strikethrough" }
    }

  ],

  "semanticHighlighting": true,

  "semanticTokenColors": {
    "namespace":              "#b87fc8",
    "namespace.declaration":  { "foreground": "#b87fc8", "bold": true },
    "class":                  "#c9a8d4",
    "class.declaration":      { "foreground": "#c9a8d4", "bold": true },
    "interface":              "#c9a8d4",
    "enum":                   "#b87fc8",
    "enumMember":             "#d090c8",
    "type":                   "#c9a8d4",
    "typeAlias":              "#c9a8d4",
    "typeParameter":          { "foreground": "#c9a8d4", "italic": true },
    "function":               "#f090d0",
    "function.declaration":   { "foreground": "#f090d0", "bold": false },
    "method":                 "#e880c8",
    "method.declaration":     "#e880c8",
    "property":               "#d8b0e0",
    "property.declaration":   "#d8b0e0",
    "property.static":        { "foreground": "#d090c8", "italic": true },
    "variable":               "#e2cfe8",
    "variable.constant":      "#d090c8",
    "variable.defaultLibrary": "#e06bbd",
    "parameter":              { "foreground": "#d8a8e0", "italic": true },
    "keyword":                "#e06bbd",
    "modifier":               "#c44fa0",
    "comment":                { "foreground": "#6a4a7a", "italic": true },
    "string":                 "#c8d8a0",
    "number":                 "#e0c878",
    "regexp":                 "#e0c878",
    "operator":               "#b07ac8",
    "decorator":              { "foreground": "#a06bc8", "italic": true },
    "label":                  "#c44fa0",
    "macro":                  "#e06bbd",
    "selfKeyword":            { "foreground": "#e06bbd", "italic": true },
    "builtinType":            "#b87fc8",
    "lifetime":               { "foreground": "#a06bc8", "italic": true }
  }
}